# ───────────────────────────────────────────────
# server（Hono API）の環境変数
# `make env-setup` でこのファイルが .env にコピーされます。
# ───────────────────────────────────────────────

# Google Cloud プロジェクト ID（必須）
GOOGLE_PROJECT_ID=route-optimization-sample

# サーバーが listen するポート（ローカル開発時のみ。Vercel では未使用）
PORT=3000

# Google 認証情報（任意 / デプロイ向け）
# - ローカル: 未設定でOK。gcloud auth application-default login の ADC を使います。
# - Vercel 等のサーバーレス環境: ADC が無いため、サービスアカウント鍵(JSON)を
#   base64 化した文字列を設定します。
#     base64 -i sa-key.json | tr -d '\n'   # macOS
#     base64 -w0 sa-key.json               # Linux
#   発行手順とデプロイ全体は docs/vercel-deploy.md を参照。
# GOOGLE_CREDENTIALS_BASE64=
