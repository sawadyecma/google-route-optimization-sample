# ───────────────────────────────────────────────
# web（Vite）の環境変数
#
# Vite では VITE_ 接頭辞の変数のみがクライアントに公開され、
# ビルド時にバンドルへ埋め込まれます（実行時には参照されません）。
# 値を変更したら再ビルド／再デプロイが必要です。
#
# `make env-setup` でこのファイルが .env.local にコピーされます。
# ※ web は GOOGLE_PROJECT_ID やサーバー側の認証情報を使いません。
# ───────────────────────────────────────────────

# Google Maps JavaScript API キー（地図表示に必須）
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# バックエンド API のベース URL（末尾スラッシュ無し）
# ローカル: make dev-server の URL / 本番: デプロイした server の URL
VITE_API_BASE_URL=http://localhost:3000
